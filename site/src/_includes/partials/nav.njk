<header class="site-header">
  <a href="/" class="site-header__brand" aria-label="Bathrooms by LV — home">
    <img src="/images/logo/Bathrooms-By-LV-FINAL.png" alt="Bathrooms by LV" width="240" height="97">
  </a>

  <button class="nav-toggle" aria-expanded="false" aria-controls="primary-nav">
    <span class="nav-toggle__bar"></span>
    <span class="nav-toggle__bar"></span>
    <span class="nav-toggle__bar"></span>
    <span class="visually-hidden">Menu</span>
  </button>

  <nav id="primary-nav" class="site-nav" aria-label="Primary">
    <ul>
      {% for item in site.nav %}
        {% set isCurrent = (page.url == item.url) or (item.url != '/' and item.url != '/#services' and page.url.indexOf(item.url) == 0) %}
        <li>
          <a href="{{ item.url }}"{% if isCurrent %} aria-current="page"{% endif %}>
            {{ item.label }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
</header>
