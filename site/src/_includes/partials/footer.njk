<footer class="site-footer">
  <div class="site-footer__grid">
    <div class="site-footer__brand">
      <img src="/images/logo/Bathrooms-By-LV-FINAL.png" alt="" width="180" height="73" loading="lazy">
      <p class="site-footer__tagline">{{ site.tagline }}</p>
    </div>

    <div class="site-footer__contact">
      <h2>Get in touch</h2>
      <ul>
        <li>{{ site.location }}</li>
        <li><a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        <li><a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a></li>
        <li><a href="tel:{{ site.landline | replace(' ', '') }}">{{ site.landline }}</a></li>
      </ul>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <h2>More</h2>
      <ul>
        {% for item in site.nav %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
        <li><a href="/privacy-policy/">Privacy policy</a></li>
      </ul>
    </nav>
  </div>

  <p class="site-footer__colophon">
    &copy; {{ site.year | default(2026) }} Bathrooms by LV. All rights reserved.
  </p>
</footer>
